{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "fcstm-gui.acceptance-check-report.v1",
  "type": "object",
  "required": ["schema", "version", "status", "platform", "viewport", "counts", "results", "geometry", "artifacts"],
  "properties": {
    "schema": {"const": "fcstm-gui.acceptance-check-report"},
    "version": {"const": 1},
    "status": {"enum": ["passed", "failed"]},
    "viewport": {"pattern": "^[0-9]+x[0-9]+$"},
    "results": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "status", "duration_ms", "detail"],
        "properties": {"status": {"enum": ["passed", "failed"]}}
      }
    },
    "geometry": {"type": "object"},
    "artifacts": {"type": "array"}
  }
}
