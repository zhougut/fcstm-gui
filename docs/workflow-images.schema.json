{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "fcstm-gui.workflow-images.v1",
  "type": "object",
  "required": [
    "schema",
    "version",
    "generated_at",
    "evidence_kind",
    "fresh_release_evidence",
    "statement",
    "source",
    "capture",
    "manual_review",
    "images"
  ],
  "properties": {
    "schema": {"const": "fcstm-gui.workflow-images"},
    "version": {"const": 1},
    "generated_at": {"type": "string", "minLength": 1},
    "evidence_kind": {"const": "source-reference"},
    "fresh_release_evidence": {"const": false},
    "statement": {"type": "string", "minLength": 1},
    "source": {
      "type": "object",
      "required": [
        "commit",
        "tree_sha",
        "worktree_dirty",
        "worktree_patch_sha256",
        "source_content_sha256"
      ],
      "properties": {
        "commit": {"type": "string", "pattern": "^[0-9a-f]{40}$"},
        "tree_sha": {"type": "string", "pattern": "^[0-9a-f]{40}$"},
        "worktree_dirty": {"type": "boolean"},
        "worktree_patch_sha256": {
          "type": "string",
          "pattern": "^[0-9a-f]{64}$"
        },
        "source_content_sha256": {
          "type": "string",
          "pattern": "^[0-9a-f]{64}$"
        }
      },
      "additionalProperties": false
    },
    "capture": {
      "type": "object",
      "required": [
        "platform",
        "platform_detail",
        "machine",
        "viewport",
        "scale",
        "qt_platform",
        "font_family",
        "font_point_size"
      ],
      "properties": {
        "platform": {"type": "string", "minLength": 1},
        "platform_detail": {"type": "string", "minLength": 1},
        "machine": {"type": "string", "minLength": 1},
        "viewport": {"type": "string", "pattern": "^[0-9]+x[0-9]+$"},
        "scale": {"type": "string", "pattern": "^[0-9]+(?:\\.[0-9]+)?$"},
        "qt_platform": {"type": "string", "minLength": 1},
        "font_family": {"type": "string", "minLength": 1},
        "font_point_size": {"type": "integer", "minimum": 1}
      },
      "additionalProperties": false
    },
    "manual_review": {
      "type": "object",
      "required": ["status", "reviewer", "reviewed_at", "findings"],
      "properties": {
        "status": {"enum": ["pending", "passed-source-reference", "failed"]},
        "reviewer": {"type": ["string", "null"]},
        "reviewed_at": {"type": ["string", "null"]},
        "findings": {"type": "array", "items": {"type": "string"}}
      },
      "additionalProperties": false
    },
    "images": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "path",
          "sha256",
          "size",
          "width",
          "height",
          "workflow",
          "stage",
          "note",
          "acceptance_id",
          "platform",
          "viewport",
          "scale",
          "font_family",
          "font_point_size"
        ],
        "properties": {
          "path": {"type": "string", "minLength": 1},
          "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
          "size": {"type": "integer", "minimum": 1000},
          "width": {"type": "integer", "minimum": 1},
          "height": {"type": "integer", "minimum": 1},
          "workflow": {"type": "string", "minLength": 1},
          "stage": {"type": "string", "pattern": "^[0-9]{2}$"},
          "note": {"type": "string", "minLength": 1},
          "acceptance_id": {"type": "string", "minLength": 1},
          "platform": {"type": "string", "minLength": 1},
          "viewport": {"type": "string", "pattern": "^[0-9]+x[0-9]+$"},
          "scale": {"type": "string", "pattern": "^[0-9]+(?:\\.[0-9]+)?$"},
          "font_family": {"type": "string", "minLength": 1},
          "font_point_size": {"type": "integer", "minimum": 1}
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
